<Window x:Class="RobloxRouteBot.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sh="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Калибровка" Height="560" Width="820" MinHeight="460" MinWidth="700"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        Background="{StaticResource BgBase}" Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI" FontSize="13" UseLayoutRounding="True">

    <sh:WindowChrome.WindowChrome>
        <sh:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0"
                         CornerRadius="0" UseAeroCaptionButtons="False"/>
    </sh:WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBase}">
        <DockPanel>

            <!-- TITLE BAR -->
            <Grid DockPanel.Dock="Top" Height="40" Background="{StaticResource BgSurface}">
                <Border BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1"/>
                <TextBlock Text="Калибровка оптического потока" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button x:Name="BtnClose" Style="{StaticResource ChromeClose}" HorizontalAlignment="Right" Height="40"
                        Click="BtnClose_Click" sh:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BB;" FontSize="10"/>
                </Button>
            </Grid>

            <!-- RIGHT RAIL -->
            <Border DockPanel.Dock="Right" Width="284" Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource Hairline}" BorderThickness="1,0,0,0">
                <StackPanel Margin="16">
                    <Button x:Name="BtnLive" Style="{StaticResource PrimaryButton}" Content="▶ Превью"
                            HorizontalAlignment="Stretch" Click="BtnLive_Click"/>

                    <!-- TELEMETRY -->
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="TELEMETRY" Style="{StaticResource Overline}"/>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Сдвиг, px" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="TxtShift" Style="{StaticResource Mono}" HorizontalAlignment="Right" Text="—"/>
                            </DockPanel>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Δ мир" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="TxtWorld" Style="{StaticResource Mono}" HorizontalAlignment="Right" Text="—"/>
                            </DockPanel>
                            <DockPanel Margin="0,2,0,6">
                                <TextBlock Text="Уверенность" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="TxtConf" Style="{StaticResource Mono}" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextMuted}" Text="—"/>
                            </DockPanel>
                            <Border x:Name="ConfTrack" Height="6" CornerRadius="3" Background="{StaticResource InputBg}"
                                    BorderBrush="{StaticResource Hairline}" BorderThickness="1">
                                <Rectangle x:Name="ConfFill" HorizontalAlignment="Left" Width="0" RadiusX="2" RadiusY="2"
                                           Fill="{StaticResource Success}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- MAPPING -->
                    <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="MAPPING" Style="{StaticResource Overline}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="px → world" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtScale" FontFamily="Consolas" TextChanged="Setting_Changed"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Поворот, °" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtRot" FontFamily="Consolas" Margin="0,8,0,0" TextChanged="Setting_Changed"/>
                            </Grid>
                            <CheckBox x:Name="ChkInvX" Content="Инверт X" Margin="0,10,0,0" Click="Setting_Changed"/>
                            <CheckBox x:Name="ChkInvY" Content="Инверт Y" Margin="0,8,0,0" Click="Setting_Changed"/>
                            <CheckBox x:Name="ChkSwap" Content="Поменять X / Y" Margin="0,8,0,0" Click="Setting_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- DETECTOR -->
                    <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="DETECTOR" Style="{StaticResource Overline}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Patch" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtPatch" FontFamily="Consolas" TextChanged="Setting_Changed"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Search" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtSearch" FontFamily="Consolas" Margin="0,8,0,0" TextChanged="Setting_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,14,0,0"
                               Text="Двигай персонажа в игре и смотри стрелку: она должна указывать туда, КУДА он едет по карте. Подгони Инверт / Swap / Поворот, чтобы совпало."/>
                </StackPanel>
            </Border>

            <!-- CAPTURE HERO -->
            <Grid Background="{StaticResource CanvasBg}">
                <Image x:Name="ImgPreview" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <Canvas x:Name="Overlay" IsHitTestVisible="False"/>
                <TextBlock x:Name="TxtHint" Text="Нажми «Превью». Нужно открытое окно игры."
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
            </Grid>

        </DockPanel>
    </Border>
</Window>
